---
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
---

<ArticleLayout back={`${import.meta.env.BASE_URL}articles/prominent-figures`}>
    <main>
        <img src={`${import.meta.env.BASE_URL}assets/figures/mary-wollstonecraft.avif`}
            alt="Mary Wollstonecraft"
            style="
                width: 100%;
                max-width: 300px;
                height: auto;
                display: block;
                margin: 0 auto;
                border-radius: 10px;
                box-shadow: 0 15px 40px rgba(0,0,0,0.8);
                animation: fadeIn 0.6s ease;"
                />

        <h2 style="text-align: center; margin-top: 20px; padding: 0 20px; font-size: 24px; animation: fadeIn 0.6s ease;">Mary Wollstonecraft</h2>
        </main>
</ArticleLayout>